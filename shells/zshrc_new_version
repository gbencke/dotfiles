export LOCAL_DATETIME=$(date +"%Y-%m-%dT%H:%M:%S%z")

FILE=~/.last_git_refresh
OLDTIME=600
CURTIME=$(date +%s)

# Check if file exists before getting modification time
if [ -f "$FILE" ]; then
    FILETIME=$(stat -c %Y "$FILE" 2>/dev/null)
    if [ -n "$FILETIME" ]; then
        TIMEDIFF=$(expr $CURTIME - $FILETIME)
    else
        # stat failed, assume file is old
        TIMEDIFF=$((OLDTIME + 1))
    fi
else
    # File doesn't exist, assume it's old
    TIMEDIFF=$((OLDTIME + 1))
fi


