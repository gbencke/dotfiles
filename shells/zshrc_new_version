# Find the next available port starting from a given port (default: 3000)
find_port() {
  local port=${1:-3000}
  while lsof -iTCP:"$port" -sTCP:LISTEN -t &>/dev/null 2>&1; do
    (( port++ ))
  done
  echo "$port"
}

# Open opencode web on the next free port starting at 9900
alias ocw='opencode web --port $(find_port 9900)'

